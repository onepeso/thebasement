{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "The Basement",
  "version": "1.1.0",
  "identifier": "com.thebasement.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "The Basement",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": true
    }
    "createUpdaterArtifacts": true,
    "identifier": "com.thebasement.desktop"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5RUREQjBCODYxQUY5NDYKUldSRytScUdDOXZ0bVZaWlpZb0pHQnJFRUdGeXE0WHlXdnNwUWtNcE5ucGZTeXRqWEM3NHN2Rm0K",
      "endpoints": [
        "https://github.com/onepeso/thebasement/releases/latest/download/latest.json"
      ]
    }
  }
}
