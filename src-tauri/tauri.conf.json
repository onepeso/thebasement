{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "The Basement",
  "version": "1.1.8",
  "identifier": "com.thebasement.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "The Basement",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://*.supabase.co https://api.dicebear.com; connect-src 'self' https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../.next/standalone": ".next/standalone"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": true
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1NzI2OUJDQkRGRTgxRjIKUldUeWdmNjl2R2x5SmNwQ3R4NG12VlB2eTNoL1dSNkxMY01lVmVKTmZhNHBhOFlQOE40c3EzaWwK",
      "endpoints": [
        "https://github.com/onepeso/thebasement/releases/latest/download/latest.json"
      ]
    }
  }
}
